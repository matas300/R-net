<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('partials/head') %>
</head>
<body>

<%- include('partials/navbar') %>

<!-- ══════════════════════════ HERO ══════════════════════════ -->
<section id="hero">
  <div class="hero-grid-bg"></div>
  <div class="hero-glow"></div>
  <div class="container">
    <div class="hero-content">
      <div class="tag">Sviluppo web &mdash; Made in Italy</div>
      <h1>Siti web <em>veloci</em>,<br>a prezzi giusti.</h1>
      <p>Dal brief alla consegna in pochi giorni. Niente fronzoli, niente sorprese in fattura &mdash; solo siti che funzionano e convertono.</p>
      <div class="hero-buttons">
        <a href="#contatti" class="btn btn-primary">
          <i class="fa-solid fa-paper-plane"></i> Richiedi un preventivo
        </a>
        <a href="#portfolio" class="btn btn-outline">
          <i class="fa-solid fa-eye"></i> Vedi i lavori
        </a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="num"><%= projects.length %><span>+</span></div>
          <div class="lbl">Clienti soddisfatti</div>
        </div>
        <div class="hero-stat">
          <div class="num">7<span>gg</span></div>
          <div class="lbl">Tempo medio consegna</div>
        </div>
        <div class="hero-stat">
          <div class="num">100<span>%</span></div>
          <div class="lbl">Mobile responsive</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════ COME LAVORIAMO ══════════════════════════ -->
<section id="come-lavoriamo">
  <div class="container">
    <div class="section-header reveal">
      <div class="tag">Il processo</div>
      <h2 class="section-title">Semplice, rapido, trasparente.</h2>
      <p class="section-sub">Nessuna burocrazia. Dal primo contatto alla messa online in pochi passaggi.</p>
    </div>
    <div class="steps-grid">
      <div class="step-card reveal">
        <div class="step-num">01</div>
        <h3>Parliamoci</h3>
        <p>Raccontami il tuo progetto. Capisco le tue esigenze, il tuo settore e cosa vuoi comunicare.</p>
      </div>
      <div class="step-card reveal">
        <div class="step-num">02</div>
        <h3>Preventivo chiaro</h3>
        <p>Ricevi un preventivo dettagliato in 24 ore. Prezzo fisso, nessun costo nascosto.</p>
      </div>
      <div class="step-card reveal">
        <div class="step-num">03</div>
        <h3>Sviluppo rapido</h3>
        <p>Lavoro veloce e iterativo. Vedi l&apos;avanzamento in tempo reale e mi dai feedback direttamente.</p>
      </div>
      <div class="step-card reveal">
        <div class="step-num">04</div>
        <h3>Consegna &amp; online</h3>
        <p>Il sito viene pubblicato, testato e ottimizzato. Ti spiego come gestirlo in autonomia.</p>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════ PORTFOLIO ══════════════════════════ -->
<section id="portfolio">
  <div class="container">
    <div class="section-header reveal">
      <div class="tag">Portfolio</div>
      <h2 class="section-title">Lavori recenti.</h2>
      <p class="section-sub">Ogni progetto &egrave; costruito su misura, da zero, con attenzione ai dettagli e alle performance.</p>
    </div>
    <div class="portfolio-filters">
      <button class="portfolio-filter active" data-filter="all">Tutti</button>
      <% const sectors = [...new Set(projects.map(p => p.sector).filter(Boolean))]; %>
      <% sectors.forEach(s => { %>
        <button class="portfolio-filter" data-filter="<%= s %>"><%= s %></button>
      <% }) %>
    </div>
    <div class="portfolio-list">
      <% projects.forEach(project => { %>
        <%- include('partials/project-card', { project }) %>
      <% }) %>
    </div>
  </div>
</section>

<!-- ══════════════════════════ PRICING ══════════════════════════ -->
<section id="prezzi">
  <div class="container">
    <div class="section-header reveal">
      <div class="tag">Prezzi</div>
      <h2 class="section-title">Chiari, fissi, onesti.</h2>
      <p class="section-sub">Nessun canone mensile obbligatorio, nessuna sorpresa. Paghi una volta, il sito &egrave; tuo.</p>
    </div>
    <div class="pricing-grid">

      <!-- Starter -->
      <div class="pricing-card reveal">
        <div class="pricing-name">Starter</div>
        <div class="pricing-price">
          <div class="amount"><span class="currency">&euro;</span>299</div>
          <span class="iva">a partire da &bull; IVA inclusa</span>
          <span class="note">una tantum &bull; consegna in ~5 giorni</span>
        </div>
        <ul class="pricing-features">
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Landing page a <strong>pagina singola</strong></span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Design personalizzato</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Ottimizzazione <strong>mobile</strong></span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>SEO base</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Form di contatto</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Consegna file sorgenti</span></li>
        </ul>
        <a href="#contatti" class="btn btn-outline">Inizia ora</a>
      </div>

      <!-- Business (featured) -->
      <div class="pricing-card featured reveal">
        <div class="badge-popular">Pi&ugrave; richiesto</div>
        <div class="pricing-name">Business</div>
        <div class="pricing-price">
          <div class="amount"><span class="currency">&euro;</span>549</div>
          <span class="iva">a partire da &bull; IVA inclusa</span>
          <span class="note">una tantum &bull; consegna in ~10 giorni</span>
        </div>
        <ul class="pricing-features">
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Sito <strong>multi-pagina</strong> (fino a 6)</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Design premium personalizzato</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>SEO avanzato + Schema markup</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Google Analytics integrato</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Animazioni &amp; interazioni</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>1 mese di <strong>supporto incluso</strong></span></li>
        </ul>
        <a href="#contatti" class="btn btn-primary">Inizia ora</a>
      </div>

      <!-- E-commerce -->
      <div class="pricing-card reveal">
        <div class="pricing-name">E-commerce</div>
        <div class="pricing-price">
          <div class="amount"><span class="currency">&euro;</span>999</div>
          <span class="iva">a partire da &bull; IVA inclusa</span>
          <span class="note">una tantum &bull; consegna in ~20 giorni</span>
        </div>
        <ul class="pricing-features">
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Sito + <strong>shop online</strong> completo</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Pagamenti con <strong>Stripe</strong></span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Gestione ordini &amp; prodotti</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>Area admin dedicata</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>SEO + Analytics avanzati</span></li>
          <li><span class="check"><i class="fa-solid fa-check"></i></span><span>3 mesi di <strong>supporto incluso</strong></span></li>
        </ul>
        <a href="#contatti" class="btn btn-outline">Inizia ora</a>
      </div>

    </div>
    <p style="text-align:center; color:var(--muted); font-size:.85rem; margin-top:2rem;">
      Hai esigenze particolari? <a href="#contatti" style="color:var(--accent)">Scrivimi</a> per un preventivo su misura. Il preventivo &egrave; sempre gratuito.
    </p>
  </div>
</section>

<!-- ══════════════════════════ CONTACT ══════════════════════════ -->
<section id="contatti">
  <div class="container">
    <div class="contact-wrap reveal">
      <div class="contact-info">
        <div class="tag">Contatti</div>
        <h2>Parliamo del tuo progetto.</h2>
        <p>Hai un&apos;idea, un&apos;attivit&agrave; da portare online o vuoi rinnovare il tuo sito? Scrivimi &mdash; rispondo entro 24 ore.</p>
        <div class="contact-methods">
          <div class="contact-method">
            <div class="icon"><i class="fa-brands fa-whatsapp"></i></div>
            <div>
              <div style="font-size:.78rem;color:var(--muted);margin-bottom:.1rem">WhatsApp (risposta rapida)</div>
              <a href="https://wa.me/<%= whatsappNumber %>" target="_blank"><%= whatsappNumber ? '+' + whatsappNumber.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})$/, '$1 $2 $3 $4') : 'Numero non configurato' %></a>
            </div>
          </div>
          <div class="contact-method">
            <div class="icon"><i class="fa-solid fa-envelope"></i></div>
            <div>
              <div style="font-size:.78rem;color:var(--muted);margin-bottom:.1rem">Email</div>
              <a href="mailto:info@sitelya.it">info@sitelya.it</a>
            </div>
          </div>
          <% if (instagramHandle) { %>
          <div class="contact-method">
            <div class="icon"><i class="fa-brands fa-instagram"></i></div>
            <div>
              <div style="font-size:.78rem;color:var(--muted);margin-bottom:.1rem">Instagram</div>
              <a href="https://instagram.com/<%= instagramHandle.replace('@','') %>" target="_blank"><%= instagramHandle.startsWith('@') ? instagramHandle : '@' + instagramHandle %></a>
            </div>
          </div>
          <% } %>
        </div>
      </div>
      <form class="contact-form" id="contact-form">
        <div class="form-group">
          <label for="nome">Nome e cognome</label>
          <input type="text" id="nome" name="nome" placeholder="Mario Rossi" required />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="mario@example.com" required />
        </div>
        <div class="form-group">
          <label for="tipo">Tipo di sito</label>
          <select id="tipo" name="tipo">
            <option value="">Seleziona...</option>
            <option value="landing">Landing page</option>
            <option value="business">Sito business</option>
            <option value="ecommerce">E-commerce</option>
            <option value="altro">Altro / non so ancora</option>
          </select>
        </div>
        <div class="form-group">
          <label for="messaggio">Descrivi brevemente il progetto</label>
          <textarea id="messaggio" name="messaggio" placeholder="Ho un'attivit&agrave; di... vorrei un sito che..." required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">
          <i class="fa-solid fa-paper-plane"></i> Invia richiesta
        </button>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<script src="/js/main.js"></script>
</body>
</html>
