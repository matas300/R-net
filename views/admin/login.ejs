<!DOCTYPE html>
<html lang="it">
<head>
  <%- include('../partials/head', { pageTitle: 'Admin Login' }) %>
  <link rel="stylesheet" href="/admin.css" />
</head>
<body class="admin-body">
  <div class="login-wrap">
    <div class="login-card">
      <div class="nav-logo" style="font-size:1.8rem;margin-bottom:2rem;text-align:center">Site<span>lya</span></div>
      <h2 style="font-family:'Inter',sans-serif; font-weight:700; margin-bottom:.5rem">Admin</h2>
      <p style="color:var(--muted); font-size:.9rem; margin-bottom:2rem">Inserisci la password per accedere.</p>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/admin/login">
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required autofocus />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; margin-top:1rem">
          <i class="fa-solid fa-right-to-bracket"></i> Accedi
        </button>
      </form>
    </div>
  </div>
</body>
</html>
